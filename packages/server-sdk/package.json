{
  "name": "@zenalyze/server-sdk",
  "version": "0.1.0",
  "description": "Server-side integration SDK for Zenalyze Encryption Platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "encryption",
    "healthcare",
    "HIPAA",
    "server",
    "api",
    "audit",
    "compliance"
  ],
  "author": "Zenalyze",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "axios-mock-adapter": "^1.22.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samuelsalfati/zenalyze-encryption-platform.git",
    "directory": "packages/server-sdk"
  }
}
